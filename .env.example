# Next server-side proxy target for AI calorie analysis
ANALYZE_API_URL=http://localhost:4000/v1/food/analyze

# Optional auth key if backend requires it
BACKEND_API_KEY=

# Optional rate limit (backend)
# ANALYZE_RATE_LIMIT_PER_MINUTE=5
# TEXT_ANALYZE_RATE_LIMIT_PER_MINUTE=10
# ANALYZE_IP_RATE_LIMIT_PER_MINUTE=20
# TEXT_ANALYZE_IP_RATE_LIMIT_PER_MINUTE=40
# ANALYZE_RATE_LIMIT_WINDOW_MS=60000

# Optional: Google Directions API key for road-based routing
GOOGLE_MAPS_API_KEY=

# Google Maps JS key for client-side map rendering
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server only; never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

