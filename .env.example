# Next server-side proxy target for AI calorie analysis
ANALYZE_API_URL=http://localhost:4000/v1/food/analyze

# Optional auth key if backend requires it
BACKEND_API_KEY=

# Optional: Google Directions API key for road-based routing
GOOGLE_MAPS_API_KEY=

# Google Maps JS key for client-side map rendering
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase service role key (server only; never expose to client)
SUPABASE_SERVICE_ROLE_KEY=
